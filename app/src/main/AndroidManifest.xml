<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher_vecino"
        android:roundIcon="@drawable/ic_launcher_vecino"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProyectoFinalMobiles">

        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".RegistroActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".FlujoVendedorActivity"
            android:exported="false" />

        <activity
            android:name=".FinalizarPedidoActivity"
            android:exported="false" />

        <activity
            android:name=".MetricasVendedorActivity"
            android:exported="false" />

        <activity
            android:name=".PanelProductosActivity"
            android:exported="false" />

        <activity
            android:name=".PedidoRuta"
            android:exported="false" />

        <activity
            android:name=".RealizarPedidoActivity"
            android:exported="false" />

        <activity
            android:name=".AgregarProductoActivity"
            android:exported="false" />

    </application>

</manifest>